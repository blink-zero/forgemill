# Forgemill Environment Variables
# Copy to .env and fill in values before running docker compose up

# REQUIRED: Random 32+ character strings for security
FORGEMILL_JWT_SECRET=change-me-to-a-random-32-plus-char-string
FORGEMILL_ENCRYPTION_KEY=change-me-to-a-random-32-plus-char-string

# REQUIRED: Initial admin credentials
FORGEMILL_ADMIN_USER=admin
FORGEMILL_ADMIN_PASSWORD=change-me

# Optional: Logging level (debug, info, warn, error)
FORGEMILL_LOG_LEVEL=info

# Optional: TLS configuration (set both to enable native HTTPS)
FORGEMILL_TLS_CERT=
FORGEMILL_TLS_KEY=

# Optional: Comma-separated list of trusted proxy IPs for X-Forwarded-For
FORGEMILL_TRUSTED_PROXIES=
